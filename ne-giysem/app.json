{
  "expo": {
    "name": "Sestina",
    "slug": "sestina",
    "scheme": "sestina",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Bulunduğun yerin hava durumuna göre kombin önermek için konum izni gerekiyor.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.monalterego.sestina"
    },
    "android": {
      "package": "com.monalterego.sestina",
      "adaptiveIcon": {
        "backgroundColor": "#FAFAFA",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Dolabına ürün eklemek için galeri erişimi gerekiyor.",
          "cameraPermission": "Ürün fotoğrafı çekmek ve taramak için kamera erişimi gerekiyor."
        }
      ],
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Bulunduğun yerin hava durumuna göre kombin önermek için konum izni gerekiyor."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#FAFAFA"
        }
      ],
      "expo-localization",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.155277061002-dnr34ehc7tm7p8bug5ua7v3sqpk9g8re"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0A0A0A"
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "97d71a2a-fac5-4a94-9a9f-11ca1ad99a4b"
      }
    },
    "owner": "monalterego",
    "updates": {
      "url": "https://u.expo.dev/97d71a2a-fac5-4a94-9a9f-11ca1ad99a4b"
    }
  }
}
